  "types": "dist/index.d.ts",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --format=esm --external:react --external:react-dom --outfile=dist/index.js && tsc --emitDeclarationOnly"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "esbuild": "^0.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.0"
  }
}
